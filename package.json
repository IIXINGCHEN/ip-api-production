{
  "name": "ip-api-production",
  "version": "2.0.0",
  "description": "Enhanced IP geolocation API with Hono framework",
  "main": "src/app.js",
  "type": "module",
  "scripts": {
    "start": "wrangler dev",
    "dev": "wrangler dev",
    "dev:remote": "wrangler dev --remote --env-file .env.development",
    "build": "npm run lint && npm run test:run",
    "deploy": "wrangler deploy --env production",
    "deploy:staging": "wrangler deploy --env staging",
    "deploy:dev": "wrangler deploy --env development",
    "audit": "npm audit --registry=https://registry.npmjs.org --audit-level moderate --omit=dev",
    "clean": "rm -rf dist node_modules/.cache",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest --watch",
    "test:security": "vitest run --testNamePattern='security|threat'"
  },
  "keywords": [
    "ip",
    "geolocation",
    "api",
    "hono",
    "edge",
    "cloudflare"
  ],
  "author": "iixingchen",
  "license": "MIT",
  "dependencies": {
    "@hono/zod-validator": "^0.5.0",
    "hono": "^4.7.10",
    "zod": "^3.25.28"
  },
  "devDependencies": {
    "@eslint/js": "^8.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^8.0.0",
    "jsdom": "^26.1.0",
    "vitest": "^3.2.4",
    "wrangler": "^4.16.1"
  }
}
