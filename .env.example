# IP Geolocation API - Environment Variables Template
# 复制此文件为 .env 并填入实际值

# ============================================
# 必需的API密钥 (Required API Keys)
# ============================================
API_KEY_ADMIN=your-secure-admin-key-here-min-32-chars
API_KEY_USER=your-secure-user-key-here-min-32-chars

# ============================================
# 环境配置 (Environment Configuration)
# ============================================
ENVIRONMENT=development
WORKER_ENV=development
NODE_ENV=development

# ============================================
# 可选的第三方服务 (Optional Third-party Services)
# ============================================
# IPInfo服务令牌
IPINFO_TOKEN=

# MaxMind GeoIP服务凭据
MAXMIND_USER_ID=
MAXMIND_LICENSE_KEY=

# ============================================
# Cloudflare Workers配置 (仅部署时需要)
# ============================================
# 注意: 这些值应通过 wrangler secret put 命令设置
# 不要在此文件中填写生产环境的敏感信息

# ============================================
# 生产环境CORS域名 (Production CORS Origins)
# ============================================
# 在environment.js中配置，不在此处设置
# 示例: https://yourdomain.com, https://api.yourdomain.com
